export class RoutingService {
  static calculateDistance(
    lat1: number,
    lon1: number,
    lat2: number,
    lon2: number
  ): number {
    const R = 6371;
    const dLat = ((lat2 - lat1) * Math.PI) / 180;
    const dLon = ((lon2 - lon1) * Math.PI) / 180;
    const a =
      Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos((lat1 * Math.PI) / 180) *
        Math.cos((lat2 * Math.PI) / 180) *
        Math.sin(dLon / 2) *
        Math.sin(dLon / 2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }

  static calculateWalkTime(distanceKm: number): number {
    return Math.round((distanceKm / 1.3) * 60);
  }

  static async planRoute(
    startStop: Stop,
    endStop: Stop,
    departureTime: Date = new Date()
  ): Promise<Route[]> {
    const distance = this.calculateDistance(
      startStop.latitude,
      startStop.longitude,
      endStop.latitude,
      endStop.longitude
    );

    const walkTime = this.calculateWalkTime(distance);

    const routes: Route[] = [
      {
        id: '1',
        startStop,
        endStop,
        departureTime,
        arrivalTime: new Date(departureTime.getTime() + (walkTime + 15) * 60000),
        duration: walkTime + 15,
        transfers: 0,
        legs: [
          {
            type: 'walk',
            duration: 2,
            distance: 0.2
          },
          {
            type: 'transit',
            line: '107',
            startStop,
            endStop,
            duration: 13,
            vehicle: 'bus'
          }
        ],
        price: 0,
        isFree: true
      },
      {
        id: '2',
        startStop,
        endStop,
        departureTime: new Date(departureTime.getTime() + 10 * 60000),
        arrivalTime: new Date(departureTime.getTime() + (25 + 15) * 60000),
        duration: 40,
        transfers: 1,
        legs: [
          {
            type: 'walk',
            duration: 3,
            distance: 0.3
          },
          {
            type: 'transit',
            line: 'T2',
            startStop,
            duration: 12,
            vehicle: 'tram'
          },
          {
            type: 'walk',
            duration: 2,
            distance: 0.15
          },
          {
            type: 'transit',
            line: 'M1',
            endStop,
            duration: 13,
            vehicle: 'metro'
          }
        ],
        price: 0,
        isFree: true
      }
    ];

    return routes;
  }

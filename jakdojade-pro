export class ZTMApi {
  static async getVehicles(type?: 'bus' | 'tram'): Promise<Vehicle[]> {
    try {
      const requests = [];
      
      if(!type || type === 'bus') {
        requests.push(
          api.get('/busestrams_get', {
            params: { resource_id: RESOURCES.BUSES, type: 1 }
          })
        );
      }
      
      if(!type || type === 'tram') {
        requests.push(
          api.get('/busestrams_get', {
            params: { resource_id: RESOURCES.TRAMS, type: 2 }
          })
        );
      }

      const responses = await Promise.all(requests);
      const vehicles: Vehicle[] = [];

      responses.forEach((response, index) => {
        const vehType = index === 0 ? 'bus' : 'tram';
        if(response.data.result) {
          vehicles.push(
            ...response.data.result.map((v: any) => ({
              id: v.VehicleNumber,
              line: v.Lines,
              latitude: parseFloat(v.Lat),
              longitude: parseFloat(v.Lon),
              bearing: v.Bearing || 0,
              speed: 0,
              brigade: v.Brigade,
              lastUpdate: new Date(),
              type: vehType
            }))
          );
        }
      });

      return vehicles;
    } catch (error) {
      console.error('Error fetching vehicles:', error);
      return [];
    }
  }

  static async getDepartures(stopId: string, stopNumber: string = '01'): Promise<Departure[]> {
    try {
      const response = await api.get('/dbtimetable_get', {
        params: {
          id: RESOURCES.SCHEDULE,
          busstopId: stopId,
          busstopNr: stopNumber,
          limit: 10
        }
      });

      if(!response.data.result) return [];

      return response.data.result.map((departure: any) => {
        const values: any = {};
        departure.values?.forEach((v: any) => {
          values[v.key] = v.value;
        });
        return {
          time: values['czas'] || values['time'],
          line: values['linia'] || values['line'],
          destination: values['kierunek'] || values['direction'],
          direction: values['kierunek'] || values['direction'],
          delay: parseInt(values['opoznienie']) || 0,
          isCancelled: values['status'] === 'ANULOWANY',
          isRealtime: !!values['czas_rzeczywisty']
        };
      });
    } catch (error) {
      console.error('Error fetching departures:', error);
      return [];
    }
  }

